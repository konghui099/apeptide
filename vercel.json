{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "regions": ["iad1", "hnd1", "sin1"],
  "functions": {
    "app/**/*.html": {
      "cacheControl": "public, max-age=0, must-revalidate"
    },
    "api/**/*.ts": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
